# to see if your .env file is working correctly by running `docker-compose config`

# the site name
NEXT_PUBLIC_APP_NAME=Web-SyncPlay

# modify if you pass your own running valkey instance
VALKEY_URL=redis://localhost:6379
NODE_ENV=development

# the binary path for yt-dlp
YTDLP_BIN=yt-dlp

# fallback media URL used when daily defaults cache is empty
FALLBACK_DEFAULT_MEDIA_URL=https://youtu.be/uD4izuDMUQA

# control-page signed token settings
CONTROL_TOKEN_SECRET=385399b00b2bba29ff22acb60df9919df91d95e39c3b96d897f5eece281e2530
CONTROL_TOKEN_TTL_SECONDS=600
